<Window x:Class="RAGChatbot.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:RAGChatbot"
        xmlns:viewmodels="clr-namespace:RAGChatbot.ViewModels"
        mc:Ignorable="d"
            Title="RAG Enterprise Chatbot" 
            Height="750" 
            Width="1100"
            MinHeight="550"
            MinWidth="800"
            WindowStartupLocation="CenterScreen"
            Background="{DynamicResource MaterialDesign.Brush.Background}">
    
    <Window.DataContext>
        <viewmodels:MainViewModel/>
    </Window.DataContext>
    
    <Grid>
        <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel - Documents & Settings -->
        <Border Grid.Column="0" 
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="16">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Grid Width="40" Height="40" Margin="0,0,12,0">
                                <Ellipse Width="40" Height="40" Fill="{DynamicResource PrimaryHueMidBrush}"/>
                                <TextBlock Text="🤖" FontSize="24" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="RAG Chatbot" 
                                       Style="{StaticResource MaterialDesignHeadline4TextBlock}"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Enterprise Document Q&amp;A" 
                                   Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                   Opacity="0.7" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Document Upload -->
                <StackPanel Grid.Row="0" Margin="16,60,16,0">
                    <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                            Command="{Binding UploadDocumentCommand}"
                            HorizontalAlignment="Stretch"
                                Height="44"
                                Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Upload" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Upload Document"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- Document List -->
                <Grid Grid.Row="1" Margin="16,16,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Indexed Documents" 
                               Style="{StaticResource MaterialDesignSubtitle2TextBlock}"
                               Margin="0,0,0,8"/>
                    
                    <ListBox Grid.Row="1" 
                             ItemsSource="{Binding Documents}"
                             SelectedItem="{Binding SelectedDocument}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource MaterialDesign.Brush.TextBox.HoverBackground}"
                                            CornerRadius="12"
                                            Padding="14,10"
                                            Margin="0,6"
                                            Effect="{DynamicResource MaterialDesignShadowElevation1}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <materialDesign:PackIcon Kind="FileDocument" 
                                                                  VerticalAlignment="Center"
                                                                  Foreground="{DynamicResource PrimaryHueMidBrush}"
                                                                  Margin="0,0,8,0"/>
                                        
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Filename}" 
                                                       TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource MaterialDesignBody2TextBlock}"/>
                                            <TextBlock Text="{Binding ChunksCount, StringFormat='{}{0} chunks'}"
                                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                       Opacity="0.6"/>
                                        </StackPanel>
                                        
                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Command="{Binding DataContext.DeleteDocumentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding Id}"
                                                ToolTip="Delete document"
                                                    Width="32" Height="32">
                                            <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
                
                <!-- Settings -->
                <StackPanel Grid.Row="2" Margin="16">
                    <Separator Margin="0,0,0,8"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Style="{StaticResource MaterialDesignCaptionTextBlock}"
                               TextWrapping="Wrap"
                               Foreground="{Binding StatusColor}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <!-- Right Panel - Chat -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Chat Header -->
            <Border Grid.Row="0" 
                    Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        Padding="20,16"
                        CornerRadius="18"
                        Effect="{DynamicResource MaterialDesignShadowElevation2}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                            <TextBlock Text="Chat" 
                                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Ask questions about your documents"
                                       Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                       Opacity="0.7" Margin="0,4,0,0"/>
                    </StackPanel>
                    
                    <Button Grid.Column="1"
                            Style="{StaticResource MaterialDesignIconButton}"
                            Command="{Binding ClearChatCommand}"
                            ToolTip="Clear chat">
                        <materialDesign:PackIcon Kind="Broom"/>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Chat Messages -->
            <ScrollViewer Grid.Row="1" 
                          x:Name="ChatScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                              Padding="24">
                <ItemsControl ItemsSource="{Binding Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,4">
                                <!-- Message -->
                                <Border Style="{Binding Role, Converter={StaticResource MessageStyleConverter}}">
                                        <StackPanel MaxWidth="540">
                                            <TextBox Text="{Binding Content, Mode=OneWay}" 
                                                       TextWrapping="Wrap"
                                                       FontSize="16"
                                                       IsReadOnly="True"
                                                       BorderThickness="0"
                                                       Background="Transparent"
                                                       Cursor="IBeam"
                                                       FontFamily="{StaticResource MaterialDesignFont}"
                                                       Padding="0"/>
                                        </StackPanel>
                                </Border>
                                
                                <!-- Sources (for assistant messages) -->
                                <ItemsControl ItemsSource="{Binding Sources}"
                                              Visibility="{Binding Sources, Converter={StaticResource NullToVisibilityConverter}}"
                                              Margin="10,4,50,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SourceChipStyle}"
                                                    ToolTip="{Binding Content}">
                                                <TextBlock Text="{Binding DocumentName}"
                                                           Style="{StaticResource MaterialDesignCaptionTextBlock}"
                                                           MaxWidth="150"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Loading Indicator -->
            <Grid Grid.Row="2" 
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                  Margin="16,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 IsIndeterminate="True"
                                     Width="24" Height="24"/>
                    <TextBlock Text="Thinking..." 
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"
                               Style="{StaticResource MaterialDesignBody2TextBlock}"
                               Opacity="0.7"/>
                </StackPanel>
            </Grid>
            
            <!-- Input Area -->
            <Border Grid.Row="3" 
                        Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                        Padding="20"
                        CornerRadius="18"
                        Effect="{DynamicResource MaterialDesignShadowElevation2}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBox x:Name="InputTextBox"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Ask a question..."
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             AcceptsReturn="False"
                             MaxLength="2000"
                             VerticalContentAlignment="Center"
                             FontSize="15"
                             Margin="0,0,0,0"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource PrimaryHueMidBrush}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SendMessageCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    
                    <Button Grid.Column="1"
                                Style="{StaticResource MaterialDesignFloatingActionButton}"
                            Command="{Binding SendMessageCommand}"
                            IsEnabled="{Binding CanSend}"
                                Margin="12,0,0,0"
                                Width="48" Height="48">
                            <materialDesign:PackIcon Kind="Send" Width="24" Height="24"/>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
