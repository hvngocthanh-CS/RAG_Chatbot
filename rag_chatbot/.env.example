# ===========================================
# RAG Enterprise Chatbot Configuration
# Production-ready with vLLM Integration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# Application Settings
# ===========================================
APP_NAME="RAG Enterprise Chatbot"
APP_VERSION=1.0.0
APP_ENVIRONMENT=development  # development, staging, production
DEBUG=false

# ===========================================
# API Settings
# ===========================================
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
API_WORKERS=4

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Request Settings
REQUEST_TIMEOUT=120
MAX_CONCURRENT_REQUESTS=50

# ===========================================
# LLM Settings
# ===========================================
LLM_PROVIDER=ollama  # ollama (local) or vllm (self-hosted)

# Ollama Settings (local LLM - no API key needed)
# Install from: https://ollama.com
# Pull model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# vLLM Settings (self-hosted)
VLLM_BASE_URL=http://localhost:8080/v1
VLLM_MODEL_NAME=microsoft/Phi-3-mini-4k-instruct
VLLM_API_KEY=not-needed

# vLLM Server Configuration (for deployment)
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=4096
# VLLM_QUANTIZATION options: awq, gptq, squeezellm, fp8 (leave empty for none)
VLLM_QUANTIZATION=
VLLM_DTYPE=auto
VLLM_TRUST_REMOTE_CODE=true

# OpenAI Settings (cloud API)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_ORG_ID=

# Generation Settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TOP_P=0.95
LLM_TOP_K=40
LLM_REPETITION_PENALTY=1.1
LLM_PRESENCE_PENALTY=0.0
LLM_FREQUENCY_PENALTY=0.0

# ===========================================
# Resilience Settings
# ===========================================
CIRCUIT_BREAKER_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=30

RETRY_ENABLED=true
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY=1.0
RETRY_MAX_DELAY=10.0
RETRY_EXPONENTIAL_BASE=2.0

FALLBACK_ENABLED=true
FALLBACK_TO_OPENAI=true

# ===========================================
# Embedding Settings
# ===========================================
EMBEDDING_PROVIDER=huggingface  # openai or huggingface
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1024
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_RETRIES=3

# ===========================================
# Vector Database
# ===========================================
VECTOR_DB_TYPE=chroma  # chroma or qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=true
CHROMA_PERSIST_DIR=./data/chroma_db
COLLECTION_NAME=documents

# ===========================================
# Document Processing
# ===========================================
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MAX_FILE_SIZE_MB=50
SUPPORTED_EXTENSIONS=[".pdf",".docx",".txt",".md"]

# ===========================================
# Retrieval Settings
# ===========================================
TOP_K_RETRIEVAL=10
TOP_K_RERANK=5
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-base
USE_HYBRID_SEARCH=true
HYBRID_ALPHA=0.5

# ===========================================
# Redis Cache
# ===========================================
USE_CACHE=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10
CACHE_TTL=3600
CACHE_KEY_PREFIX=rag:

# ===========================================
# Storage
# ===========================================
UPLOAD_DIR=./data/uploads
PROCESSED_DIR=./data/processed

# ===========================================
# Observability
# ===========================================
# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_FORMAT=json  # json or text
LOG_ROTATION=10 MB
LOG_RETENTION=30 days

# Metrics (Prometheus)
METRICS_ENABLED=true
METRICS_PORT=9090
METRICS_PATH=/metrics

# Tracing (OpenTelemetry)
TRACING_ENABLED=false
OTLP_ENDPOINT=
SERVICE_NAME=rag-chatbot

# Health Check
HEALTH_CHECK_INTERVAL=30
HEALTH_CHECK_TIMEOUT=10

# ===========================================
# Security Settings
# ===========================================
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true
API_KEY_HEADER=X-API-Key
API_KEYS=[]  # JSON array of valid API keys (empty = no auth)
